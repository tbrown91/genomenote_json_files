{
    "$schema": "https://json-schema.org/draft/2020-12/schema#",
    "type": "object",
    "source": [
        "ToLPortal"
    ],
    "properties": {
        "methods": {
            "type": "object",
            "help": "Methods used to extract genomic material from provided samples. These are kept as separate subsections because they are populated from different workflow sources.",
            "properties": {
                "sample_processing": {
                    "type": "array",
                    "help": "Details of extraction methods/protocols.",
                    "items": {
                        "type": "object",
                        "properties": {
                            "sample_role": {
                                "enum": [
                                    "pacbio",
                                    "hic",
                                    "ont",
                                    "rna",
                                    "isoseq",
                                    "chromium",
                                    "other"
                                ],
                                "help": "Role of this sample in the genome note workflow."
                            },
                            "nucleic_acid_extraction": {
                                "type": "array",
                                "help": "Wet-lab extraction and tissue-preparation metadata.",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "sample_role": {
                                            "enum": [
                                                "pacbio",
                                                "hic",
                                                "rna",
                                                "isoseq",
                                                "chromium",
                                                "other"
                                            ]
                                        },
                                        "sample_accession": {
                                            "type": "string"
                                        },
                                        "extraction_uid": {//Is this needed in this schema? Try to separate IDs used to extract data internally vs. what is presented in the final "publication"
                                            "type": "string"
                                        },
                                        "tissue_prep_uid": {//Same as above
                                            "type": "string"
                                        },
                                        "extraction_protocol": {
                                            "type": "string",
					    "help": "Give identifier of protocol in References"
                                        },
                                        "extraction_protocol_plaintext": {
                                            "type": "string",
					    "help": "Publication-ready plaintext summary of the extraction protocol"
                                        },
                                        "protocol": {//Not sure what this means
                                            "type": "string",
                                            "help": "Display name for the extraction protocol, where separate from extraction_protocol."
                                        },
                                        "dna_yield_ng": {//Happy to include these as optional fields, but it is a lot
                                            "type": "number",
                                            "minimum": 0
                                        },
                                        "volume_ul": {
                                            "type": "number",
                                            "minimum": 0
                                        },
                                        "qubit_ngul": {
                                            "type": "number",
                                            "minimum": 0
                                        },
                                        "ratio_260_280": {
                                            "type": "number"
                                        },
                                        "ratio_260_230": {
                                            "type": "number"
                                        },
                                        "nanodrop_concentration_ngul": {
                                            "type": "number",
                                            "minimum": 0
                                        },
                                        "fragment_size_kb": {
                                            "type": "number",
                                            "minimum": 0
                                        },
                                        "gqn": {
                                            "type": "number",
                                            "minimum": 0
                                        },
                                        "spri_type": {
                                            "type": "string"
                                        },
                                        "disruption_method": {
                                            "type": "string"
                                        },
                                        "tissue_type": {
                                            "type": "string"
                                        },
                                        "tissue_weight_mg": {
                                            "type": "number",
                                            "minimum": 0,
                                            "help": "Mass/weight of tissue taken for extraction, in milligrams."
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
