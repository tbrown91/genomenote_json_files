{
    "$schema": "https://json-schema.org/draft/2020-12/schema#",
    "type": "object",
    "source": [
        "STS"
    ],
    "properties": {
        "sample_accession": {
            "type": "string",
            "help": "BioSample accession for the sample used for this workflow role."
        },
        "sample_derived_from": {
            "type": "string",
            "help": "Source individual or parent BioSample accession, where different from sample_accession."
        },
        "tolid": {
            "type": "string"
        },
        "specimen_id": {
            "type": "string"
        },
        "organism_part": {
            "type": "string",
            "help": "SHOULD THIS BE IN A SUBGROUP? WHICH ONE, PRESERVATION?"
        },
        "preservation_data": {
            "type": "array",
            "properties": {
                "sample_id": "string",
                "method": {
                    "type": "string",
                    "help": "Method of preservation used"
                },
                "solution": {
                    "type": "string",
                    "help": "Storage solution"
                }
            }
        },
        "identification_data": {
            "type": "array",
            "properties": {
                "sample_id": "string",
                "scientific_name": "string",
                "method": {
                    "type": "string",
                    "help": "How was the organism identified?"
                },
                "sex": {
                    "type": "string"
                },
                "lifestage": {
                    "type": "string"
                }
            }
        },
        "collection_data": {
            "type": "array",
            "properties": {
                "sample_id": "string",
                "method": {
                    "type": "string",
                    "help": "How was the sample collected"
                },
                "date": {
                    "type": "string",
                    "help": "Date of collection"
                },
                "location": {
                    "help": "Name of town/city/region",
                    "type": "string"
                },
                "country": {
                    "help": "Country of Origin",
                    "type": "string"
                },
                "latitude": {
                    "type": "number"
                },
                "longitude": {
                    "type": "number"
                },
                "elevation": {
                    "type": "number",
                    "help": "Elevation the sample was collected at, in metres"
                }
            }
        },
        "involved_persons": {
            "type": "array",
            "properties": {
                "name": {
                    "type": "string",
                    "help": "Name of the collector/identifier of sample"
                },
                "role": {
                    "enum": [
                        "collector",
                        "identifier",
                        "other"
                    ]
                },
                "affiliation": {
                    "type": "string",
                    "help": "Affiliation of person"
                },
                "gal": {
                    "type": "string",
                    "help": "Genome Acquisition Lab."
                }
            }
        },
        "specimen_images": {
            "type": "array",
            "help": "Images of the collected specimen or source individual used in the genome note.",
            "items": {
                "type": "object",
                "properties": {
                    "image": {
                        "type": "string"
                    },
                    "link": {
                        "type": "string"
                    },
                    "caption": {
                        "type": "string"
                    }
                }
            }
        }
    }
}
