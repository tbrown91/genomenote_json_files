{
    "$schema": "https://json-schema.org/draft/2020-12/schema#",
    "type": "object",
    "help": "Likely for V2 in the future",
    "properties": {
        "annotation": {
            "type": "array",
            "help": "Annotation method performed and output TB: Ideally link to workflow (doi) and optional free text description",
            "properties": {
                "accession": "string",
                "data_used": {
                    "type": "array",
                    "properties": {
                        "accession": "string"
                    }
                },
                "method": "string",
                "statistics": {
                    "type": "object",
                    "help": "Key statistics of annotation outcomes TB: Bit of a brain dump, can be refined later",
                    "properties": {
                        "no_genes": "integer",
                        "mean_gene_length": "number",
                        "mean_mrna_length": "number",
			"no_single_exon_genes": "integer",
			"busco": {
                        "type": "array",
                        "properties": {
                            "lineages": {
                                "odb_name": "string",
                                "complete": {
                                    "type": "number",
                                    "minimum": 0,
                                    "help": "Number/Percentage of complete busco genes"
                                },
                                "single": {
                                    "type": "number",
                                    "minimum": 0,
                                    "help": "Number/Percentage of single busco genes"
                                },
                                "duplicate": {
                                    "type": "number",
                                    "minimum": 0,
                                    "help": "Number/Percentage of duplicate busco genes"
                                },
                                "fragmented": {
                                    "type": "number",
                                    "minimum": 0,
                                    "help": "Number/Percentage of fragmented busco genes"
                                },
                                "missing": {
                                    "type": "number",
                                    "minimum": 0,
                                    "help": "Number/Percentage of missing busco genes"
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
