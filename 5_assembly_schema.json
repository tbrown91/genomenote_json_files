{
    "$schema": "https://json-schema.org/draft/2020-12/schema#",
    "type": "object",
    "source": [
        "ToLQC"
    ],
    "properties": {
        "assembly_methods": {
            "type": "object",
            "$comment": "KvN: Assembly methods and curation methods are related but not the same. Assembly methods describe how the assembly was generated, scaffolded and purged before or during production of the submitted assembly.",
            "properties": {
                "involved_persons": {
                    "type": "array",
                    "properties": {
                        "name": {
                            "type": "string",
                            "help": "Name of assembler"
                        },
                        "role": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "enum": [
                                    "assembler",
                                    "annotation",
                                    "other"
                                ]
                            },
                            "minItems": 1,
                            "uniqueItems": true
                        },
                        "affiliation": {
                            "type": "string",
                            "help": "Affiliated group"
                        }
                    }
                },
                "assembly_method_text": {
                    "type": "string",
                    "help": "Publication-ready or template-generated text describing the assembly method."
                },
                "assembly_software": {
                    "type": "array",
                    "help": "Software/Pipelines used for assembly generation, scaffolding or purging, for example Hifiasm, purge_dups or YaHS.",
                    "items": {
                        "type": "object",
                        "properties": {
                            "name": {
                                "type": "string"
                            },
                            "version": {
                                "type": "string"
                            },
                            "purpose": {
                                "type": "string"
                            },
                            "parameters": {
                                "type": "string"
                            },
                            "source": {
                                "type": "string"
                            }
                        }
                    }
                },
                "hifiasm_data": {
                    "type": "object",
                    "source": [
                        "ToLQC"
                    ],
                    "properties": {
                        "phasing_mode": {
                            "enum": [
                                "hic_phasing",
                                "original",
                                "other"
                            ],
                            "help": "Whether Hifiasm was run in Hi-C phasing mode or original/non-Hi-C mode."
                        },
                        "cli_options": {
                            "type": "string",
                            "help": "Hifiasm command-line options where these affect the published assembly method, for example --primary -l0."
                        },
                        "formatted_cli_options": {
                            "type": "string",
                            "help": "Publication-ready sentence derived from Hifiasm options by data_note."
                        },
                        "primary_mode": {
                            "type": "boolean",
                            "help": "Whether Hifiasm primary mode was used."
                        },
                        "internal_purging_disabled": {
                            "type": "boolean",
                            "help": "Whether Hifiasm internal purging was disabled."
                        }
                    }
                },
                "organelle_assembly": {
                    "type": "array",
                    "help": "Organelle assembly steps or decisions, including assembler and comparator where relevant.",
                    "items": {
                        "type": "object",
                        "properties": {
                            "organelle_type": {
                                "enum": [
                                    "mitochondrion",
                                    "plastid",
                                    "chloroplast",
                                    "other"
                                ]
                            },
                            "assembler": {
                                "type": "object",
                                "properties": {
                                    "name": "string",
                                    "version": "string",
                                    "doi": "string",
                                    "url": "string"
                                },
                                "help": "Tool or workflow used for organelle assembly, for example MitoHiFi or Oatk."
                            },
                            "comparator": {
                                "type": "array",
                                "properties": {
                                    "name": "string",
                                    "accession": "string"
                                },
                                "help": "Comparator species, assembly or reference used for organelle assembly, where applicable."
                            },
                            "decision_notes": {
                                "type": "string",
                                "help": "Short note on organelle assembly choices or review decisions."
                            }
                        }
                    }
                }
            }
        },
        "assembly_stats": {
            "type": "array",
            "properties": {
                "assembly_information": {
                    "type": "object",
                    "properties": {
                        "id": "string",
                        "assembly_level": {
                            "enum": [
                                "contig",
                                "scaffold",
                                "chromosome"
                            ]
                        },
                        "accession_haplotype": {
                            "type": "string",
                            "help": "This should be Primary, Alternate OR Primary followed by Haplotype_{int}. This should act as a key where noted HAP_KEY"
                        },
                        "assembly_accession": {
                            "type": "string"
                        },
                        "assembly_id": {
                            "type": "string"
                        },
                        "no_of_contigs": {
                            "type": "integer"
                        },
                        "contig_n50_length": {
                            "type": "number"
                        },
                        "no_of_scaffolds": {
                            "type": "integer"
                        },
                        "scaffold_n50_length": {
                            "type": "number"
                        },
                        "longest_scaffold_length": {
                            "type": "number"
                        },
                        "genome_size": {
                            "type": "number"
                        },
                        "percent_assembled": {
                            "type": "array",
                            "properties": {
                                "haplotype": "string",
                                "minimum": 0,
                                "maximum": 100,
                                "help": "Percentage of the assembly assigned to chromosomes. 1 item per haplotype in the array. HAP_KEY"
                            }
                        }
                    },
                    "organelles": {
                        "type": "array",
                        "help": "Organelle sequences included in the assembly, such as mitochondrial and plastid genomes.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "assembly_role": {
                                    "type": "string",
                                    "help": "Assembly role containing this organelle record. HAP_KEY"
                                },
                                "organelle_type": {
                                    "enum": [
                                        "mitochondrion",
                                        "plastid",
                                        "chloroplast"
                                    ]
                                },
                                "accession": {
                                    "type": "string"
                                },
                                "name": {
                                    "type": "string",
                                    "help": "Molecule name, for example MT or PLTD."
                                },
                                "description": {
                                    "type": "string"
                                },
                                "length_kb": {
                                    "type": "number",
                                    "minimum": 0
                                },
                                "gc_percent": {
                                    "type": "number",
                                    "minimum": 0,
                                    "maximum": 100
                                }
                            }
                        }
                    }
                }
            },
            "assembly_analysis": {
                "type": "object",
                "properties": {
                    "ncbi_taxonomy_id": {
                        "type": "string",
                        "minLength": 1
                    },
                    "ploidy": {
                        "method": {
                            "type": "object",
                            "properties": {
                                "software": "string",
                                "doi": "string",
                                "url": "string"
                            }
                        },
                        "count": {
                            "type": "number",
                            "help": "Ploidy count"
                        },
                        "formatted_count": {
                            "type": "string",
                            "help": "Whether the count equates to diploid, triploid, etc."
                        }
                    },
                    "kmer_analysis": {
                        "type": "array",
                        "properties": {
                            "name": {
                                "enum": [
                                    "genomescope",
                                    "smudgeplot"
                                ]
                            },
                            "path": {
                                "type": "string",
                                "help": "Path to directory containing results"
                            },
                            "est_size_bp": {
                                "type": "number",
                                "minimum": 0,
                                "help": "Estimated length of assembly from analysis, recorded in base-pairs"
                            }
                        }
                    },
                    "raw_data_object": {
                        "type": "array",
                        "help": "Linked to raw_data in sample_prep_schema",
                        "properties": {
                            "accession": "string",
                            "data_type": "string"
                        }
                    },
                    "chromosome_tables": {
                        "help": "Chromosomal pseudomolecules",
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "insdc_accession": {
                                    "type": "string"
                                },
                                "chromosome": {
                                    "type": "string"
                                },
                                "size_mb": {
                                    "type": "number"
                                },
                                "gc_percent": {
                                    "type": "number"
                                }
                            }
                        }
                    },
                    "taxonomy": {
                        "help": "What species",
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "assembly_id": "string",
                                "tax_authority": "string",
                                "ncbi_taxonomy_id": {
                                    "type": "string",
                                    "minLength": 1
                                },
                                "lineage": {
                                    "type": "string"
                                },
                                "class": {
                                    "type": "string"
                                },
                                "family": {
                                    "type": "string"
                                },
                                "order": {
                                    "type": "string"
                                },
                                "phylum": {
                                    "type": "string"
                                },
                                "common_name": {
                                    "type": "string",
                                    "help": "Common name used in the genome note. In data_note this is taken from GBIF when available, or NCBI Datasets as fallback."
                                },
                                "common_name_source": {
                                    "enum": [
                                        "gbif",
                                        "ncbi_datasets"
                                    ],
                                    "help": "Source used for common_name."
                                },
                                "species": {
                                    "type": "string"
                                }
                            },
                            "required": [
                                "ncbi_taxonomy_id"
                            ]
                        }
                    }
                }
            }
        }
    }
}
