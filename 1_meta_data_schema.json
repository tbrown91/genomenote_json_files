{
    "$schema": "https://json-schema.org/draft/2020-12/schema#",
    "type": "object",
    "properties": {
        "metadata": {
            "type": "object",
            "properties": {
                "template_version": {
                    "type": "string"
                },
                "doi": {
                    "type": "string"
                },
                "data_availability": {
                    "type": "string"
                },
                "title": {
                    "type": "string"
                },
                "abstract": {
                    "type": "string"
                },
                "keywords": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "background": {
                    "type": "string"
                },
                "bioproject": {
                    "type": "string"
                },
                "child_bioprojects": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "help": "Child BioProjects associated with the main BioProject; used to ID sequencing run metadata."
                },
                "parent_projects": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "accession": {
                                "type": "string"
                            },
                            "name": {
                                "type": "string"
                            },
                            "project_name": {
                                "type": "string"
                            },
                            "title": {
                                "type": "string"
                            }
                        }
                    },
                    "help": "Parent BioProjects associated with the main BioProject. Used to derive formatted_parent_projects."
                },
                "formatted_parent_projects": {
                    "type": "string",
                    "help": "Publication-ready parent project string derived from parent_projects by data_note. Describes, e.g. Project Psyche."
                },
                "authors": {
                    "type": "array",
                    "source": [
                        "AuthorsDB"
                    ],
                    "items": {
                        "type": "object",
                        "properties": {
                            "surname": {
                                "type": "string"
                            },
                            "given_names": {
                                "type": "string"
                            },
                            "roles": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            },
                            "orcid": {
                                "type": "string"
                            },
                            "corresponding": {
                                "type": "boolean"
                            },
                            "affiliations": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                "affiliations": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "id": {
                                "type": "string"
                            },
                            "affiliation": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "required": [
                "doi",
                "title"
            ]
        },
        "publication_metadata": {
            "type": "object",
            "source": [
                "AuthorsDB"
            ],
            "properties": {
                "funding": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "source": {
                                "type": "string"
                            },
                            "award_ids": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            },
                            "funding_statement": {
                                "type": "string"
                            }
                        }
                    }
                },
                "journal_data": {
                    "type": "array",
                    "properties": {
                        "journal_name": "string",
                        "e_location_id": "string",
                        "license": "string",
                        "submission_date": "string",
                        "publication_date": "string"
                    }
                },
                "genome_note_data": {
                    "submission_date": "string",
                    "publication_date": "string"
                },
                "ebp_analysis_metrics": {
                    "type": "array"
                },
                "acknowledgements": {
                    "type": "string"
                },
                "ethics_and_consent": {
                    "type": "object"
                },
                "competing_interests": {
                    "type": "string"
                }
            }
        }
    }
}
