{
    "$schema": "https://json-schema.org/draft/2020-12/schema#",
    "type": "object",
    "source": [
        "tolqc",
        "STS"
    ],
    "properties": {
        "metadata": {
            "type": "object",
            "properties": {
                "template_version": {
                    "type": "string"
                },
                "doi": {
                    "type": "string",
                    "help": "DOI, without the https://doi.org/ prefix, example is: 10.1080/10509585.2015.1092083",
                    "pattern": "^10\\.\\d{4,9}/\\S+$"
                },
                "data_availability": {
                    "type": "string"
                },
                "title": {
                    "type": "string"
                },
                "abstract": {
                    "type": "string",
                    "help": "Markdown is fine"
                },
                "keywords": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "background": {
                    "type": "string"
                },
                "bioproject": {
                    "type": "string"
                },
                "child_bioprojects": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "help": "Child BioProjects associated with the main BioProject; used to ID sequencing run metadata."
                },
                "parent_projects": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "accession": {
                                "type": "string"
                            },
                            "name": {
                                "type": "string"
                            },
                            "project_name": {
                                "type": "string"
                            },
                            "title": {
                                "type": "string"
                            }
                        }
                    },
                    "help": "Parent BioProjects associated with the main BioProject. Used to derive formatted_parent_projects."
                },
                "formatted_parent_projects": {
                    "type": "string",
                    "help": "Publication-ready parent project string derived from parent_projects by data_note. Describes, e.g. Project Psyche."
                },
                "authors": {
                    "type": "array",
                    "source": [
                        "AuthorsDB"
                    ],
                    "items": {
                        "type": "object",
                        "properties": {
                            "authorsdb_id": {
                                "type": "string",
                                "help": "ID from AuthorsDB"
                            },
                            "surname": {
                                "type": "string",
                                "help": "Family name of the author"
                            },
                            "middle_names": {
                                "type": "string",
                                "help": "Middle names of the author"
                            },
                            "given_names": {
                                "type": "string",
                                "help": "Given names of the author (First name)"
                            },
                            "gal_association": {
                                "type": "string",
                                "help": "GAL association if applicable - Collectors ONLY"
                            },
                            "role": {
                                "type": "array",
                                "items": {
                                    "type": "string",
                                    "enum": [
                                        "assembler",
                                        "curator",
                                        "data_generator",
                                        "annotation",
                                        "collection",
                                        "extraction",
                                        "sequencing",
                                        "researcher",
                                        "other"
                                    ]
                                },
                                "minItems": 1,
                                "uniqueItems": true
                            },
                            "orcid": {
                                "type": "string"
                            },
                            "corresponding": {
                                "type": "boolean"
                            },
                            "affiliations": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                "affiliations": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "id": {
                                "type": "string"
                            },
                            "affiliation": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "required": [
                "doi",
                "title"
            ]
        },
        "publication_metadata": {
            "type": "object",
            "source": [
                "AuthorsDB"
            ],
            "properties": {
                "funding": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "source": {
                                "type": "string"
                            },
                            "award_ids": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            },
                            "funding_statement": {
                                "type": "string"
                            }
                        }
                    }
                },
                "journal_data": {
                    "type": "array",
                    "properties": {
                        "journal_name": "string",
                        "e_location_id": "string",
                        "license": "string",
                        "submission_date": "string",
                        "publication_date": "string"
                    }
                },
                "genome_note_data": {
                    "submission_date": "string",
                    "publication_date": "string"
                },
                "ebp_analysis_metrics": {
                    "type": "array" <-- already exists in analysis, do we need it in two places?
                },
                "acknowledgements": {
                    "type": "string"
                },
                "ethics_and_consent": {
                    "type": "object",
                    "properties": {
                        <-- What should be here
                    }
                },
                "competing_interests": {
                    "type": "string"
                }
            }
        }
    }
}
