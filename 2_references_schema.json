{
    "$schema": "https://json-schema.org/draft/2020-12/schema#",
    "type": "object",
    "properties": {
        "references": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "id",
                    "citation_key",
                    "publication_type"
                ],
                "properties": {
                    "id": {
                        "type": "string",
                        "help": "Name of reference material"
                    },
                    "citation_key": {
                        "type": "string",
                        "help": "Stable key used for in-text citations and bibliography matching. This should match the BibTeX key or CSL id used by Pandoc or by the portal citation processor."
                    },
                    "publication_type": {
                        "enum": [
                            "article",
                            "preprint",
                            "book/chapter",
                            "dataset",
                            "report",
                            "webpage",
                            "protocol",
                            "conference_proceedings",
                            "software/workflow"
                        ]
                    },
                    "authors": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "surname": {
                                    "type": "string"
                                },
                                "given_names": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "payload": {
                        "type": "object"
                    }
                },
                "anyOf": [
                    {
                        "properties": {
                            "publication_type": {
                                "const": "article"
                            }
                        }
                    }
                ]
            }
        }
    }
}
"article_title": {
    "type": "string"
},
"source": {
    "type": "string"
},
"year": {
    "type": "string"
},
"volume": {
    "type": "string"
},
"issue": {
    "type": "string"
},
"first_page": {
    "type": "string"
},
"last_page": {
    "type": "string"
},
"doi": {
    "type": "string"
},
"url": {
    "type": "string"
},
"pmid": {
    "type": "string"
},
"pmcid": {
    "type": "string"
}
}
}
}
}
}
