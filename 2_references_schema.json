{
    "$schema": "https://json-schema.org/draft/2020-12/schema#",
    "type": "object",
    "properties": {
        "references": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "publication_type": {
                        "type": "string"
                    },
                    "authors": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "surname": {
                                    "type": "string"
                                },
                                "given_names": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "article_title": {
                        "type": "string"
                    },
                    "source": {
                        "type": "string"
                    },
                    "year": {
                        "type": "string"
                    },
                    "volume": {
                        "type": "string"
                    },
                    "issue": {
                        "type": "string"
                    },
                    "first_page": {
                        "type": "string"
                    },
                    "last_page": {
                        "type": "string"
                    },
                    "doi": {
                        "type": "string"
                    },
                    "pmid": {
                        "type": "string"
                    },
                    "pmcid": {
                        "type": "string"
                    }
                }
            }
        }
    }
}
