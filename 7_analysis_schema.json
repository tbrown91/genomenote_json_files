{
    "$schema": "https://json-schema.org/draft/2020-12/schema#",
    "type": "object",
    "source": [
        "ToLQC",
        "GAP/WorkflowsDB",
        "meta-notes"
    ],
    "properties": {
        "analysis": {
            "type": "array",
            "properties": {
                "sample_id": {
                    "type": "string",
                    "help": "Links to HAP_KEY"
                },
                "assembly_role": {
                    "assembly": "string",
                    "help": "Links to HAP_KEY, e.g. Haplotype_1"
                },
                "ebp_statistics": {
                    "type": "object",
                    "properties": {
                        "ebp_metric": {
                            "type": "string",
                            "pattern": "^[0-9?]+\\.[0-9C?]+\\.Q[0-9?]+$",
                            "help": "Derived EBP summary metric for the assembly used in the Genome Note table, for example 6.C.Q40."
                        },
                        "ebp_reference_standard": {
                            "type": "string",
                            "help": "EBP reference standard used as the benchmark for the table, for example 6.C.Q40 or 5.C.Q40."
                        },
                        "ebp_reference_standard_reason": {
                            "type": "string",
                            "help": "Reason this reference standard was selected, for example standard_input, manual_override, low_input_material or uli."
                        },
                        "ebp_reference_standard_met": {
                            "type": [
                                "boolean",
                                "null"
                            ],
                            "help": "Whether the selected assembly meets the EBP reference standard; absent or null if required metrics are missing."
                        },
                        "ebp_reference_standard_status": {
                            "enum": [
                                "met",
                                "not_met",
                                "unknown"
                            ],
                            "help": "Derived status for the selected EBP reference standard."
                        },
                        "ebp_reference_standard_failures": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "help": "Derived list of failed EBP criteria, for example contig_n50_below_standard, percent_assigned_to_chromosomes_below_standard or qv_below_standard."
                        },
                        "ebp_reference_standard_missing_metrics": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            },
                            "help": "Derived list of required EBP input metrics that were unavailable."
                        },
                        "ebp_contig_n50_benchmark_mb": {
                            "type": "number",
                            "minimum": 0,
                            "help": "Contig N50 benchmark for the selected EBP reference standard, in megabases."
                        },
                        "ebp_contig_n50_benchmark_label": {
                            "type": "string",
                            "help": "Display label for the contig N50 benchmark, for example >= 1 Mb."
                        },
                        "ebp_perc_assembled_benchmark": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 100,
                            "help": "Percentage assigned to chromosomes required by the selected EBP reference standard."
                        },
                        "ebp_qv_benchmark": {
                            "type": "number",
                            "minimum": 0,
                            "help": "QV required by the selected EBP reference standard."
                        }
                    }
                },
                "GAP_analysis_data": {
                    "readmapping": {
                        "datablob_id": "string",
                        "aligned_reads": {
                            "type": "array",
                            "properties": {
                                "accession": "string",
                                "data_type": "string",
                                "file_path": "string",
                                "weblink": "string"
                            }
                        },
                        "sequence_composition": {}
                    },
                    "blobtoolkit": {
                        "type": "object",
                        "properties": {
                            "snail_plot": {
                                "type": "string",
                                "help": "Publication figure asset for the BlobToolKit snail plot, usually generated for hap1 or the primary assembly."
                            },
                            "blob_plot": {
                                "type": "string",
                                "help": "Publication figure asset for the BlobToolKit blob plot, usually generated for hap1 or the primary assembly."
                            },
                            "snail_plot_url": {
                                "type": "string",
                                "help": "BlobToolKit viewer URL for the snail plot, included in the genome note text."
                            },
                            "blob_plot_url": {
                                "type": "string",
                                "help": "BlobToolKit viewer URL for the blob plot, included in the genome note text."
                            }
                        }
                    },
                    "ancestral_linkage_group": {
                        "assembly_id": "string",
                        "lineage_odb": "string",
                        "ancestral_linkage_tsv": "string",
                        "ancestral_linkage_plot": "string"
                    },
                    "pretext": {
                        "assembly_id": "string",
                        "haplotype": "string",
                        "file_path": "string",
                        "weblink": "string"
                    },
                    "higlass": {
                        "assembly_id": "string",
                        "haplotype": "string",
                        "mcool_file": "string",
                        "weblink": "string"
                    },
                    "merqury": {
                        "type": "array",
                        "help": "Merqury consensus quality and k-mer completeness values reported for each assembly role.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "qv": {
                                    "type": "number",
                                    "minimum": 0,
                                    "help": "Merqury consensus quality value."
                                },
                                "kmer_completeness_percent": {
                                    "type": "number",
                                    "minimum": 0,
                                    "maximum": 100,
                                    "help": "Merqury k-mer completeness percentage."
                                },
                                "kmer_length": {
                                    "type": "integer",
                                    "minimum": 0,
                                    "help": "Length of the k-mer used for analysis."
                                },
                                "spectra_plot": {
                                    "type": "string",
                                    "help": "Optional publication figure or asset for the Merqury spectra plot."
                                }
                            }
                        }
                    },
                    "busco": {
                        "type": "array",
                        "help": "BUSCO completeness results.",
                        "items": {
                            "type": "object",
                            "properties": {
                                "lineage": {
                                    "type": "string",
                                    "help": "BUSCO lineage dataset, for example lepidoptera_odb10."
                                },
                                "complete_percent": {
                                    "type": "number",
                                    "minimum": 0,
                                    "maximum": 100,
                                    "help": "Percentage of complete BUSCOs."
                                },
                                "single_percent": {
                                    "type": "number",
                                    "minimum": 0,
                                    "maximum": 100,
                                    "help": "Percentage of single-copy complete BUSCOs."
                                },
                                "duplicated_percent": {
                                    "type": "number",
                                    "minimum": 0,
                                    "maximum": 100,
                                    "help": "Percentage of duplicated complete BUSCOs."
                                },
                                "fragmented_percent": {
                                    "type": "number",
                                    "minimum": 0,
                                    "maximum": 100,
                                    "help": "Percentage of fragmented BUSCOs."
                                },
                                "missing_percent": {
                                    "type": "number",
                                    "minimum": 0,
                                    "maximum": 100,
                                    "help": "Percentage of missing BUSCOs."
                                },
                                "n_markers": {
                                    "type": "integer",
                                    "minimum": 0,
                                    "help": "Number of BUSCOs in the lineage dataset."
                                },
                                "summary": {
                                    "type": "string",
                                    "help": "Display string, for example C:99.0% [S:98.6%, D:0.4%], F:0.2%, M:0.8%, n:5286."
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
